{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "rootDir": "./src",
    "outDir": "out",
    "lib": [
      "es2022"
    ],
    "types": [
      "node",
      "vscode"
    ],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
  },
  "exclude": [
    "node_modules",
    ".vscode-test",
    "scripts",
    "vitest.config.ts",
    "**/*.spec.ts",
    "test/**/*"
  ]
}
